.................... {
....................     struct
....................     {
....................         union
....................         {
....................             struct
....................             {
....................                 Flash_t piclog;
....................                 Flash_t environment;
....................                 Flash_t iv_header;
....................                 Flash_t iv_data;
....................             } logdata;
....................             uint8_t reserve[63];
