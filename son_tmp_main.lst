.................... // ============================================================================
.................... 
.................... // гғҡгғӘгғ•гӮ§гғ©гғ«гҒ®еҲқжңҹеҢ– (гғ”гғігҒ®еҮәеҠӣиЁӯе®ҡгҒӘгҒ©)
.................... void io_init(void);
.................... 
.................... // гӮўгғҠгғӯгӮ°гӮ№гӮӨгғғгғҒгҒ®еҲҮгӮҠжӣҝгҒҲ (0гҖң3гғҒгғЈгғігғҚгғ«)
.................... void switch_channel(uint8_t ch);
.................... 
.................... // LTC2452гҒӢгӮү16bitгҒ®ADCеҖӨгӮ’иӘӯгҒҝеҸ–гӮӢ
.................... uint16_t read_adc_ltc2452(void);
.................... 
.................... // иЁҲжё¬гӮ·гғјгӮұгғігӮ№гҒ®е®ҹиЎҢгҒЁFlashгҒёгҒ®дҝқеӯҳ (IVгғҮгғјгӮҝ пјӢ жё©еәҰгғҮгғјгӮҝгӮ’йҖЈз¶ҡе®ҹиЎҢ)
.................... // mode: еӢ•дҪңгғўгғјгғү
.................... // channel: жё¬е®ҡгғҒгғЈгғігғҚгғ« (MAX4734EUB+ гҒ®йҒёжҠһ)
.................... // samplingRate: гӮөгғігғ—гғӘгғігӮ°гғ¬гғјгғҲиЁӯе®ҡеҖӨ
.................... void execute_measurement(uint8_t mode, uint8_t channel, uint8_t samplingRate);
.................... 
