.................... 
.................... // гғ•гғ©гғғгӮ·гғҘгӮ«гӮҰгғігӮҝж§ӢйҖ дҪ“ (11 Bytes)
.................... typedef struct
.................... {
....................     uint8_t   mission_id;
....................     uint32_t  used_counter;
....................     uint32_t  uncopied_counter;
....................     uint8_t   reserve_counter1;
....................     uint8_t   reserve_counter2;
.................... } Flash_t;
.................... 
.................... // гғҶгғјгғ–гғ«дҝқеӯҳз”ЁгҒ®64Byteгғ‘гӮұгғғгғҲж§ӢйҖ дҪ“
.................... typedef union
.................... {
....................     struct
....................     {
....................         union
....................         {
....................             struct
....................             {
....................                 Flash_t piclog;
....................                 Flash_t environment;
....................                 Flash_t iv_header;
....................                 Flash_t iv_data;
....................             } logdata;
....................             uint8_t reserve[63];
....................         } payload;
....................         uint8_t crc; // 1гғҗгӮӨгғҲгҒ®CRC
....................     } packet;
....................     uint8_t bytes[64];
.................... } FlashData_t;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t end_address;
.................... } MisfStatusStruct;
.................... 
.................... typedef struct
.................... {
....................     uint32_t start_address;
....................     uint32_t size;
.................... } MisfWriteStruct;
