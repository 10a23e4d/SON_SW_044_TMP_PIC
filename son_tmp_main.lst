....................     // ------------------------------------------
....................     #use spi(MASTER, BAUD=1000000, MODE=0, BITS=8, DI=PIN_B5, DO=PIN_B4, CLK=PIN_B2, stream=MIS_FM_STREAM, FORCE_SW)
