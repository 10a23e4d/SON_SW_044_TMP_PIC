....................     unsigned int8  zeroFill;       // 1 Byte (هگˆè¨ˆ8Byteمپ«مپ™م‚‹مپںم‚پ)
.................... } PacketHeader;
.................... 
.................... typedef struct
.................... {
....................     PacketHeader header;           // 8 Byte
....................     unsigned int8 packetNum;       // 1 Byte
