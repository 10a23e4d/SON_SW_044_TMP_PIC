.................... MisfStatusStruct get_misf_status_struct(uint8_t mission_id)
.................... {
....................     MisfStatusStruct mis_struct = {0, 0};
.................... 
....................     // â€»ه®ڑو•° (CIGS_PICLOG_DATA ç­‰) مپ¯ه¤–éƒ¨ه…±é€ڑمƒکمƒƒمƒ€مپ«ن¾‌ه­ک
....................     if (mission_id == CIGS_PICLOG_DATA)
