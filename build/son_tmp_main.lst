.................... // ============================================================================
.................... // グローバル変数
.................... // ============================================================================
.................... // 64Byte境界合わせのための4Byteパディング用データ
.................... uint8_t PICLOG_BLANK_DATA[PICLOG_BLANK_SIZE] = {0x00, 0x00, 0x00, 0x00};
.................... 
.................... // ============================================================================
.................... // ログ作成とフラッシュ保存処理
.................... // ============================================================================
