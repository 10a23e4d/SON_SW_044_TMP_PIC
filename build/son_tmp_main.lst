.................... // ログを作成し、フラッシュメモリに書き込む
.................... // function: イベントID
.................... // parameter: 状態パラメータ
.................... void piclog_make(uint8_t function, uint8_t parameter);
.................... 
.................... #endif // son_tmp_PICLOG_H
