.................... // ============================================================================
.................... // ό╕σί║οήΔΘήΔ╝ήΓ┐ύΦρήΔΣήΓ▒ήΔΔήΔΙόπΜώΑιϊ╜Υ (64Byte)
.................... // ============================================================================
.................... typedef struct
.................... {
....................     uint8_t packetNum;       // ήΔΣήΓ▒ήΔΔήΔΙύΧςίΠ╖ (1 Byte)
....................     uint8_t tempData[62];    // ό╕σί║οήΔΘήΔ╝ήΓ┐όευϊ╜Υ (62 Byte = 12bit x 41ήΔΘήΔ╝ήΓ┐)
....................     uint8_t crc8;            // CRC-8 (1 Byte)
.................... } TempPacket;
