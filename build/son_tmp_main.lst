00D4A:  BCF    F8C.5
00D4C:  DECFSZ x55,F
00D4E:  BRA    0D54
00D50:  BRA    0D5A
00D52:  MOVLB  0
00D54:  MOVLB  0
00D56:  GOTO   0D32
00D5A:  MOVLB  0
00D5C:  RETURN 0
.................... 
.................... 
.................... #endif
