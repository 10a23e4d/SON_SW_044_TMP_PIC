.................... // ίνΨώΔρίΖυώΨΜώΨλόΧ░ήΔΩήΔφήΔΙήΓ┐ήΓνήΔΩ
.................... // ============================================================================
.................... 
.................... // ήΔγήΔςήΔΧήΓπήΔσήΔτήΒχίΙζόεθίΝΨ (ήΔΦήΔ│ήΒχίΘ║ίΛδϋρφίχγήΒςήΒσ)
.................... void io_init(void);
.................... 
.................... // ήΓλήΔΛήΔφήΓ░ήΓ╣ήΓνήΔΔήΔΒήΒχίΙΘήΓΛόδ┐ήΒΙ (0ήΑε3ήΔΒήΔμήΔ│ήΔΞήΔτ)
.................... void switch_channel(uint8_t ch);
.................... 
.................... // LTC2452ήΒΜήΓΚ16bitήΒχADCίΑνήΓΤϋςφήΒ┐ίΠΨήΓΜ
.................... uint16_t read_adc_ltc2452(void);
.................... 
.................... // ϋρΙό╕υήΓ╖ήΔ╝ήΓ▒ήΔ│ήΓ╣ήΒχίχθϋκΝήΒρFlashήΒ╕ήΒχϊ┐ζίφα (IVήΔΘήΔ╝ήΓ┐ Ύ╝Μ ό╕σί║οήΔΘήΔ╝ήΓ┐ήΓΤώΑμύ╢γίχθϋκΝ)
.................... // mode: ίΜΧϊ╜εήΔλήΔ╝ήΔΚ
.................... // channel: ό╕υίχγήΔΒήΔμήΔ│ήΔΞήΔτ (MAX4734EUB+ ήΒχώΒ╕όΛη)
.................... // samplingRate: ήΓ╡ήΔ│ήΔΩήΔςήΔ│ήΓ░ήΔυήΔ╝ήΔΙϋρφίχγίΑν
.................... void execute_measurement(uint8_t mode, uint8_t channel, uint8_t samplingRate);
.................... 
