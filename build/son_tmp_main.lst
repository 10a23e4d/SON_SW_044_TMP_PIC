.................... 
.................... // ミッションの全体シーケンスを実行する
.................... // ここから core/measurement/son_tmp_strain.c の計測関数を呼び出す
.................... void execute_mission_sequence(void);
.................... 
.................... #endif // son_tmp_MODE_MISSION_H
