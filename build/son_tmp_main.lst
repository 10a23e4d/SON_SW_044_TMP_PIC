.................... 
.................... // 計測シーケンスの実行とFlashへの保存 (IVデータ ＋ 温度データを連続実行)
.................... // mode: 動作モード
.................... // channel: 測定チャンネル (MAX4734EUB+ の選択)
.................... // samplingRate: サンプリングレート設定値
.................... void execute_measurement(uint8_t mode, uint8_t channel, uint8_t samplingRate);
.................... 
.................... #endif // son_tmp_strain_H
