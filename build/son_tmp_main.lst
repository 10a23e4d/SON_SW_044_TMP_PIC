.................... 
.................... //==============================================================================
.................... // .cファイル統合（CCS C単一コンパイル単位）
.................... //==============================================================================
.................... 
.................... // ハードウェア層実装ファイル
.................... #include "../hardware/mcu/src/timer.c"
.................... // 一つ上の階層にある timer.h をインクルード
.................... #include "../timer.h"
.................... #ifndef TIMER_H
.................... #define TIMER_H
.................... 
.................... #include <stdint.h>
.................... 
.................... // __________ values _________
.................... 
.................... // パケットヘッダーの timestamp で使用するための秒カウンタ
.................... extern volatile uint32_t sec;
.................... 
.................... 
.................... // __________ functions _________
.................... uint32_t get_current_sec();
.................... void set_current_sec(uint32_t new_sec);
.................... void setup_timer();
.................... 
.................... #INT_TIMER1
.................... void TIMER1_isr();
.................... 
.................... #endif
.................... 
.................... 
.................... volatile uint32_t sec = 0;
.................... volatile uint8_t timer_tick_100ms = 0;
.................... 
.................... #INT_TIMER1
.................... void TIMER1_isr()
.................... {
....................     set_timer1(15536);
*
000BE:  MOVLW  3C
000C0:  MOVWF  FCF
000C2:  MOVLW  B0
000C4:  MOVWF  FCE
000C6:  NOP   
....................     timer_tick_100ms++;
000C8:  MOVLB  1
000CA:  INCF   x41,F
.................... 
....................     if (timer_tick_100ms >= 10)
000CC:  MOVF   x41,W
000CE:  SUBLW  09
000D0:  BTFSS  FD8.0
000D2:  BRA    00DA
000D4:  MOVLB  0
000D6:  GOTO   00F2
000DA:  MOVLB  0
