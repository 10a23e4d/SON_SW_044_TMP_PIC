....................     unsigned int8 crc8;            // 1 Byte
.................... } FirstPacket;
.................... 
.................... typedef struct
.................... {
....................     unsigned int8 packetNum;       // 1 Byte
....................     unsigned int16 adcData[31];    // 62 Byte
....................     unsigned int8 crc8;            // 1 Byte
.................... } SubsequentPacket;
.................... 
.................... typedef union
.................... {
