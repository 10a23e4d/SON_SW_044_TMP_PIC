.................... 
.................... // SMF転送準備 (CMD_SMF_PREPARE 受信時に実行)
.................... void prepare_smf_transfer(void);
.................... 
.................... // SMFデータ転送実行 (REQ_SMF_COPY 受信時に実行)
.................... void execute_smf_transfer(void);
